---
interface Props {
  variant?: "pill" | "block";
}
const { variant = "pill" } = Astro.props;

const base =
  variant === "pill"
    ? "inline-flex items-center justify-center h-9 w-9 rounded-md border border-[var(--color-border-2)] bg-transparent text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] hover:bg-[var(--color-panel)] hover:border-[var(--color-rule)] transition-colors"
    : "inline-flex items-center justify-between w-full gap-3 px-4 py-4 rounded-md hover:bg-[var(--color-panel)] transition-colors";
---

<button
  type="button"
  data-theme-toggle
  aria-label="Toggle theme"
  aria-pressed="false"
  class={base}
>
  {
    variant === "block" && (
      <span class="font-display text-lg font-medium text-[var(--color-ink)]">Theme</span>
    )
  }
  <span class="inline-flex items-center justify-center h-5 w-5 relative">
    <svg
      class="theme-icon-moon h-[18px] w-[18px]"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
    </svg>
    <svg
      class="theme-icon-sun h-[18px] w-[18px]"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
    </svg>
  </span>
</button>
