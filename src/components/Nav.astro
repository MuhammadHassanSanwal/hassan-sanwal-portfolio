---
import { site, nav } from "../data/content";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="sticky top-0 z-50 bg-[color-mix(in_srgb,var(--color-bg)_88%,transparent)] backdrop-blur border-b border-[var(--color-border)]">
  <div class="shell flex items-center justify-between gap-4 px-5 sm:px-8 py-3.5">
    <a href="#top" class="flex items-baseline gap-3 min-w-0 group">
      <span class="font-display font-semibold tracking-tight text-[1.02rem] text-[var(--color-ink)]">
        {site.name}
      </span>
      <span class="hidden sm:inline font-mono text-[0.62rem] uppercase tracking-[0.18em] text-[var(--color-muted)]">
        — {site.locationShort}
      </span>
    </a>

    <!-- Desktop nav — table-of-contents style with page numbers -->
    <nav class="hidden lg:flex items-center gap-1">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="group flex items-baseline gap-1.5 px-3 py-2 text-sm text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] transition-colors"
          >
            <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-[var(--color-muted)] group-hover:text-[var(--color-accent)] transition-colors">
              {item.page}
            </span>
            <span class="font-display">{item.label}</span>
          </a>
        ))
      }
      <span class="mx-2 h-5 w-px bg-[var(--color-border-2)]" aria-hidden="true"></span>
      <ThemeToggle />
      <a href="#contact" class="btn-primary ml-2 !py-2 !px-3.5 !text-[0.88rem]">
        Let's talk
        <span aria-hidden="true">→</span>
      </a>
    </nav>

    <!-- Mobile controls -->
    <div class="lg:hidden flex items-center gap-2">
      <ThemeToggle />
      <button
        type="button"
        data-nav-toggle
        aria-expanded="false"
        aria-label="Open menu"
        class="inline-flex items-center gap-2 px-3.5 py-2 rounded-md border border-[var(--color-border-2)] bg-transparent font-mono text-[0.7rem] uppercase tracking-[0.1em] text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] hover:border-[var(--color-rule)] transition-colors"
      >
        Menu
        <span class="flex flex-col gap-[3px]">
          <span class="block h-[1.5px] w-4 bg-current"></span>
          <span class="block h-[1.5px] w-4 bg-current"></span>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile panel — feels like opening the table of contents -->
  <div
    data-nav-panel
    data-open="false"
    class="lg:hidden fixed inset-0 top-0 pt-20 px-5 bg-[var(--color-bg)] data-[open=false]:pointer-events-none data-[open=false]:opacity-0 data-[open=true]:opacity-100 transition-opacity duration-300 z-40 overflow-y-auto"
  >
    <div class="shell pb-10">
      <p class="eyebrow mb-6">Table of Contents</p>
      <nav class="flex flex-col">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="group flex items-baseline justify-between py-4 border-b border-[var(--color-border)] hover:text-[var(--color-accent)] transition-colors"
            >
              <span class="font-display text-3xl font-semibold tracking-[-0.02em] text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors">
                {item.label}
              </span>
              <span class="font-mono text-xs tracking-[0.14em] text-[var(--color-muted)]">
                {item.page}
              </span>
            </a>
          ))
        }
      </nav>
      <a href="#contact" class="btn-primary mt-8 w-full justify-center">
        Let's talk
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>
