---
import { contact, site } from "../data/content";
---

<section id="contact" class="section border-t border-[var(--color-border)]">
  <div class="shell px-5 sm:px-8">
    <div class="ornament mb-12" aria-hidden="true">§</div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10" data-reveal>
      <aside class="lg:col-span-2">
        <p class="eyebrow">closing</p>
      </aside>

      <div class="lg:col-span-10">
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-[var(--color-muted)] mb-4">
          Closing · Contact
        </p>
        <p class="font-hand text-5xl sm:text-6xl text-[var(--color-accent)] leading-none mb-4">
          {contact.salutation}
        </p>
        <h2 class="font-display font-semibold tracking-[-0.035em] text-4xl sm:text-5xl lg:text-6xl leading-[1.04] max-w-4xl">
          {contact.headline}
        </h2>
        <p class="mt-6 text-lg sm:text-xl text-[var(--color-ink-soft)] max-w-2xl">
          {contact.subline}
        </p>

        <div class="mt-10 grid grid-cols-1 lg:grid-cols-12 gap-6">
          <!-- Primary email card — like a pasted business card -->
          <a
            href={`mailto:${site.email}`}
            class="paper lg:col-span-7 p-7 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5 hover:bg-[var(--color-bg-2)] transition-colors"
          >
            <div class="flex flex-col min-w-0 flex-1 overflow-hidden">
              <span class="eyebrow">write to me</span>
              <span class="mt-2 font-display font-semibold tracking-[-0.025em] text-[var(--color-ink)] whitespace-nowrap text-[clamp(0.95rem,2.7vw,1.3rem)]">
                {site.email}
              </span>
            </div>
            <span class="font-display text-3xl sm:text-4xl text-[var(--color-accent)] transition-transform group-hover:translate-x-1 group-hover:-translate-y-1">
              ↗
            </span>
          </a>

          <!-- CTAs -->
          <div class="lg:col-span-5 flex flex-col gap-3">
            <a href={`mailto:${site.email}`} class="btn-primary justify-center">
              {contact.cta}
              <span aria-hidden="true">→</span>
            </a>
            {
              site.resumeUrl && (
                <a href={site.resumeUrl} class="btn-ghost justify-center" target="_blank" rel="noopener">
                  Download résumé (PDF)
                  <span aria-hidden="true">↓</span>
                </a>
              )
            }
            <div class="paper p-5 mt-2">
              <p class="eyebrow mb-3">Elsewhere</p>
              <ul class="flex flex-col gap-1">
                {
                  site.socials.map((s) => (
                    <li>
                      <a
                        href={s.href}
                        class="group flex items-center justify-between py-2 text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] transition-colors"
                      >
                        <span class="font-display font-medium">{s.label}</span>
                        <span class="font-mono text-xs text-[var(--color-muted)] group-hover:text-[var(--color-accent)] transition-colors">
                          {s.handle} ↗
                        </span>
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
