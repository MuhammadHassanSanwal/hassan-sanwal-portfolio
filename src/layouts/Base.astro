---
import "../styles/global.css";
import { site } from "../data/content";

interface Props {
  title?: string;
  description?: string;
  /** Path to a 1200x630 social image, relative to /public. */
  ogImage?: string;
  /** Override the canonical URL; defaults to the current page URL. */
  canonical?: string;
  /** "website" for the homepage, "article" for blog posts, etc. */
  ogType?: "website" | "article" | "profile";
}

const {
  title = `${site.name} — ${site.title}`,
  description = `${site.name} (${site.fullName}) — ${site.title} based in ${site.location}. I design and build AI-driven automation, backend services, and full-stack products that replace entire workflows, not single tasks.`,
  ogImage = "/og-image.png",
  canonical,
  ogType = "website",
} = Astro.props;

// Astro.site is set in astro.config.mjs. Astro.url is the current page URL
// at build time. We resolve everything to fully-qualified absolute URLs so
// crawlers, Slack/iMessage/Twitter unfurlers, and JSON-LD validators are
// all happy.
const siteUrl = Astro.site ?? new URL("https://hassan-sanwal-portfolio.vercel.app");
const canonicalUrl = canonical
  ? new URL(canonical, siteUrl).toString()
  : new URL(Astro.url.pathname, siteUrl).toString();
const absoluteOgImage = new URL(ogImage, siteUrl).toString();
const resumeAbsoluteUrl = site.resumeUrl
  ? new URL(site.resumeUrl, siteUrl).toString()
  : undefined;

const sameAs = site.socials
  .filter((s) => !s.href.startsWith("mailto:"))
  .map((s) => s.href);

// Schema.org Person + WebSite. Person is the right primary entity here
// because this is a personal portfolio. WebSite enables the search-action
// hint (we don't have site search, so we omit it) and ties the URL to the
// person via `mainEntity`.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.fullName,
  alternateName: site.name,
  url: siteUrl.toString(),
  image: absoluteOgImage,
  email: `mailto:${site.email}`,
  jobTitle: site.title,
  description,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Lahore",
    addressCountry: "PK",
  },
  worksFor: {
    "@type": "Organization",
    name: "RobustCraft",
  },
  knowsAbout: [
    "AI Automation",
    "n8n",
    "LangChain",
    "Agentic AI",
    "Full-Stack Development",
    "Next.js",
    "Node.js",
    "Flutter",
    "Salesforce",
    "GoHighLevel",
    "Vapi",
  ],
  sameAs,
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: `${site.name} — Portfolio`,
  url: siteUrl.toString(),
  inLanguage: "en",
  author: { "@type": "Person", name: site.fullName },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="author" content={site.fullName} />
    <meta
      name="keywords"
      content="Hassan Sanwal, Muhammad Hassan Sanwal, automation engineer, AI automation engineer, n8n developer, full-stack developer, LangChain, Next.js, Node.js, Flutter, Lahore, Pakistan, freelance"
    />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/og-image.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />

    {/* Theme color. The no-flash script below rewrites this on first paint
        so it matches the user's actual resolved theme, but we also ship a
        media-queried pair so the OS bar tints correctly before JS runs. */}
    <meta name="theme-color" content="#F5EFE1" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#17130D" media="(prefers-color-scheme: dark)" />

    {/* ---- Open Graph (Facebook, LinkedIn, iMessage, Slack, Discord) ---- */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:secure_url" content={absoluteOgImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.title}`} />

    {/* ---- Twitter / X ---- */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={`${site.name} — ${site.title}`} />

    {/* ---- JSON-LD: Person + WebSite ---- */}
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />

    {/* Hint browsers about the resume PDF so the Download button feels
        instant on click (downloaded only once the user actually asks). */}
    {resumeAbsoluteUrl && (
      <link rel="prefetch" href={site.resumeUrl} as="document" />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Caveat:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- No-flash theme init. Default is LIGHT; users can flip to dark. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          // Default to LIGHT. Only honor system dark preference if user
          // has explicitly set it as a stored preference.
          var theme = stored || "light";
          document.documentElement.setAttribute("data-theme", theme);
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta)
            meta.setAttribute(
              "content",
              theme === "dark" ? "#17130D" : "#F5EFE1"
            );
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-[var(--color-ink)] focus:text-[var(--color-bg)] focus:px-4 focus:py-2 font-mono text-xs rounded"
    >
      Skip to content
    </a>
    <slot />

    <div class="toast-root" aria-live="polite" aria-atomic="true">
      <div class="toast" data-toast role="status"></div>
    </div>

    <script>
      // ---- Reveal on scroll ---------------------------------------------
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.08, rootMargin: "0px 0px -30px 0px" }
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

      // ---- Live local clock ---------------------------------------------
      const clockEls = document.querySelectorAll<HTMLElement>("[data-clock]");
      if (clockEls.length) {
        const fmt = new Intl.DateTimeFormat([], {
          hour: "2-digit",
          minute: "2-digit",
          hour12: false,
        });
        const tick = () => {
          const now = fmt.format(new Date());
          clockEls.forEach((el) => (el.textContent = now));
        };
        tick();
        setInterval(tick, 1000 * 30);
      }

      // ---- Theme toggle (light / dark) ----------------------------------
      const themeToggles = document.querySelectorAll<HTMLButtonElement>(
        "[data-theme-toggle]"
      );
      const metaTheme = document.querySelector<HTMLMetaElement>(
        'meta[name="theme-color"]'
      );
      const setTheme = (t: "light" | "dark") => {
        document.documentElement.setAttribute("data-theme", t);
        try {
          localStorage.setItem("theme", t);
        } catch {}
        if (metaTheme) {
          metaTheme.setAttribute("content", t === "dark" ? "#17130D" : "#F5EFE1");
        }
        themeToggles.forEach((btn) => {
          btn.setAttribute("aria-label", `Switch to ${t === "light" ? "dark" : "light"} theme`);
          btn.setAttribute("aria-pressed", t === "dark" ? "true" : "false");
        });
      };
      themeToggles.forEach((btn) => {
        btn.addEventListener("click", () => {
          const current = document.documentElement.getAttribute("data-theme");
          setTheme(current === "light" ? "dark" : "light");
        });
      });
      setTheme(
        (document.documentElement.getAttribute("data-theme") as "light" | "dark") ||
          "light"
      );

      // ---- Mailto → also copy to clipboard + toast ---------------------
      // Many users don't have a default email client set (especially on
      // Windows / Gmail-web users), so `mailto:` silently does nothing.
      // We always copy the address to the clipboard and surface a toast
      // so the action never feels broken.
      const toastEl = document.querySelector<HTMLElement>("[data-toast]");
      let toastTimer: number | undefined;
      const showToast = (msg: string) => {
        if (!toastEl) return;
        toastEl.textContent = msg;
        toastEl.classList.add("is-visible");
        if (toastTimer) window.clearTimeout(toastTimer);
        toastTimer = window.setTimeout(() => {
          toastEl.classList.remove("is-visible");
        }, 2400);
      };

      // Legacy + modern copy fallback so it works in every context
      // (including when clipboard-API permission is denied or the doc
      // isn't focused).
      const copyEmailToClipboard = (email: string): boolean => {
        let ok = false;
        try {
          if (navigator.clipboard?.writeText) {
            navigator.clipboard.writeText(email).catch(() => {});
            ok = true;
          }
        } catch {}
        try {
          const ta = document.createElement("textarea");
          ta.value = email;
          ta.setAttribute("readonly", "");
          ta.style.cssText = "position:absolute;left:-9999px;top:0;opacity:0;";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
          ok = true;
        } catch {}
        return ok;
      };

      document
        .querySelectorAll<HTMLAnchorElement>('a[href^="mailto:"]')
        .forEach((a) => {
          a.addEventListener("click", () => {
            const email = (a.getAttribute("href") || "")
              .replace(/^mailto:/i, "")
              .split("?")[0];
            if (!email) return;
            const ok = copyEmailToClipboard(email);
            showToast(
              ok ? "Email copied to clipboard" : email
            );
          });
        });

      // ---- Mobile nav toggle --------------------------------------------
      const navToggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
      const navPanel = document.querySelector<HTMLElement>("[data-nav-panel]");
      const navCloseBtn = document.querySelector<HTMLButtonElement>("[data-nav-close]");
      const navLabel = document.querySelector<HTMLElement>("[data-nav-label]");

      if (navToggle && navPanel) {
        const setOpen = (open: boolean) => {
          navPanel.classList.toggle("is-open", open);
          navToggle.setAttribute("aria-expanded", open ? "true" : "false");
          navToggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
          if (navLabel) navLabel.textContent = open ? "Close" : "Menu";
          document.body.classList.toggle("nav-open", open);
        };

        navToggle.addEventListener("click", () => {
          setOpen(!navPanel.classList.contains("is-open"));
        });
        navCloseBtn?.addEventListener("click", () => setOpen(false));

        // Close when any nav link is tapped
        navPanel.querySelectorAll("a").forEach((a) =>
          a.addEventListener("click", () => setOpen(false))
        );

        // Escape key closes the panel
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && navPanel.classList.contains("is-open")) {
            setOpen(false);
            navToggle.focus();
          }
        });

        // If the viewport grows past lg while open, auto-close so we don't
        // leave a stray open class around.
        const mql = window.matchMedia("(min-width: 64rem)");
        const onMqlChange = (ev: MediaQueryListEvent | MediaQueryList) => {
          if ((ev as MediaQueryList).matches ?? (ev as MediaQueryListEvent).matches) {
            setOpen(false);
          }
        };
        if (mql.addEventListener) {
          mql.addEventListener("change", onMqlChange);
        } else {
          // Older Safari
          mql.addListener(onMqlChange);
        }
      }
    </script>
  </body>
</html>
