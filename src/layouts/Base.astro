---
import "../styles/global.css";
import { site } from "../data/content";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — ${site.title}`,
  description = `${site.name} (${site.fullName}) — ${site.title} based in ${site.location}. Automation systems, backend services and full-stack products.`,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#F5EFE1" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Caveat:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- No-flash theme init. Default is LIGHT; users can flip to dark. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          // Default to LIGHT. Only honor system dark preference if user
          // has explicitly set it as a stored preference.
          var theme = stored || "light";
          document.documentElement.setAttribute("data-theme", theme);
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta)
            meta.setAttribute(
              "content",
              theme === "dark" ? "#17130D" : "#F5EFE1"
            );
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-[var(--color-ink)] focus:text-[var(--color-bg)] focus:px-4 focus:py-2 font-mono text-xs rounded"
    >
      Skip to content
    </a>
    <slot />

    <div class="toast-root" aria-live="polite" aria-atomic="true">
      <div class="toast" data-toast role="status"></div>
    </div>

    <script>
      // ---- Reveal on scroll ---------------------------------------------
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.08, rootMargin: "0px 0px -30px 0px" }
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

      // ---- Live local clock ---------------------------------------------
      const clockEls = document.querySelectorAll<HTMLElement>("[data-clock]");
      if (clockEls.length) {
        const fmt = new Intl.DateTimeFormat([], {
          hour: "2-digit",
          minute: "2-digit",
          hour12: false,
        });
        const tick = () => {
          const now = fmt.format(new Date());
          clockEls.forEach((el) => (el.textContent = now));
        };
        tick();
        setInterval(tick, 1000 * 30);
      }

      // ---- Theme toggle (light / dark) ----------------------------------
      const themeToggles = document.querySelectorAll<HTMLButtonElement>(
        "[data-theme-toggle]"
      );
      const metaTheme = document.querySelector<HTMLMetaElement>(
        'meta[name="theme-color"]'
      );
      const setTheme = (t: "light" | "dark") => {
        document.documentElement.setAttribute("data-theme", t);
        try {
          localStorage.setItem("theme", t);
        } catch {}
        if (metaTheme) {
          metaTheme.setAttribute("content", t === "dark" ? "#17130D" : "#F5EFE1");
        }
        themeToggles.forEach((btn) => {
          btn.setAttribute("aria-label", `Switch to ${t === "light" ? "dark" : "light"} theme`);
          btn.setAttribute("aria-pressed", t === "dark" ? "true" : "false");
        });
      };
      themeToggles.forEach((btn) => {
        btn.addEventListener("click", () => {
          const current = document.documentElement.getAttribute("data-theme");
          setTheme(current === "light" ? "dark" : "light");
        });
      });
      setTheme(
        (document.documentElement.getAttribute("data-theme") as "light" | "dark") ||
          "light"
      );

      // ---- Mailto → also copy to clipboard + toast ---------------------
      // Many users don't have a default email client set (especially on
      // Windows / Gmail-web users), so `mailto:` silently does nothing.
      // We always copy the address to the clipboard and surface a toast
      // so the action never feels broken.
      const toastEl = document.querySelector<HTMLElement>("[data-toast]");
      let toastTimer: number | undefined;
      const showToast = (msg: string) => {
        if (!toastEl) return;
        toastEl.textContent = msg;
        toastEl.classList.add("is-visible");
        if (toastTimer) window.clearTimeout(toastTimer);
        toastTimer = window.setTimeout(() => {
          toastEl.classList.remove("is-visible");
        }, 2400);
      };

      // Legacy + modern copy fallback so it works in every context
      // (including when clipboard-API permission is denied or the doc
      // isn't focused).
      const copyEmailToClipboard = (email: string): boolean => {
        let ok = false;
        try {
          if (navigator.clipboard?.writeText) {
            navigator.clipboard.writeText(email).catch(() => {});
            ok = true;
          }
        } catch {}
        try {
          const ta = document.createElement("textarea");
          ta.value = email;
          ta.setAttribute("readonly", "");
          ta.style.cssText = "position:absolute;left:-9999px;top:0;opacity:0;";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
          ok = true;
        } catch {}
        return ok;
      };

      document
        .querySelectorAll<HTMLAnchorElement>('a[href^="mailto:"]')
        .forEach((a) => {
          a.addEventListener("click", () => {
            const email = (a.getAttribute("href") || "")
              .replace(/^mailto:/i, "")
              .split("?")[0];
            if (!email) return;
            const ok = copyEmailToClipboard(email);
            showToast(
              ok ? "Email copied to clipboard" : email
            );
          });
        });

      // ---- Mobile nav toggle --------------------------------------------
      const navToggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
      const navPanel = document.querySelector<HTMLElement>("[data-nav-panel]");
      if (navToggle && navPanel) {
        const close = () => {
          navPanel.dataset.open = "false";
          navToggle.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
        };
        navToggle.addEventListener("click", () => {
          const open = navPanel.dataset.open === "true";
          if (open) {
            close();
          } else {
            navPanel.dataset.open = "true";
            navToggle.setAttribute("aria-expanded", "true");
            document.body.style.overflow = "hidden";
          }
        });
        navPanel.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
      }
    </script>
  </body>
</html>
